{
  "name": "perch",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A personal, pluggable developer dashboard pinned to your desktop.",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bins:install": "node scripts/install-bins.mjs",
    "bins:uninstall": "node scripts/install-bins.mjs --uninstall"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.13.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
