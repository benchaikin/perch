{
  "name": "@perch/gui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -b && node esbuild.mjs",
    "start": "electron .",
    "dev": "node esbuild.mjs && concurrently -k -n esbuild,electron -c blue,green \"node esbuild.mjs --watch\" \"electronmon .\"",
    "dist": "pnpm build && electron-builder build --mac",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\""
  },
  "electronmon": {
    "patterns": [
      "dist/**"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@perch/cli": "workspace:*",
    "@perch/core": "workspace:*",
    "@perch/plugin-agents": "workspace:*",
    "@perch/plugin-dex": "workspace:*",
    "@perch/plugin-services": "workspace:*",
    "@perch/plugin-stack": "workspace:*",
    "@perch/plugin-worktrees": "workspace:*",
    "@perch/sdk": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.2",
    "electronmon": "^2.0.3",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1"
  },
  "build": {
    "appId": "com.perch.app",
    "productName": "Perch",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/perchd.cjs"
    ],
    "mac": {
      "target": "dir",
      "identity": null,
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools"
    }
  }
}
