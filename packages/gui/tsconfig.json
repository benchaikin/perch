{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    // Keep the incremental-build cache inside dist so `rm -rf dist` fully resets
    // the build (otherwise a stale cache makes tsc skip re-emitting deleted JS).
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    // The renderer + preload run in the browser/Electron, so they need DOM types
    // alongside Node. esbuild produces the actual browser bundles; tsc here is
    // for type-checking + emitting the Node main process.
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    // React renderer: type-check .tsx with the automatic JSX runtime, matching
    // esbuild's jsx:"automatic" so neither needs an `import React`.
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src"],
  "references": [
    { "path": "../sdk" },
    { "path": "../core" },
    { "path": "../cli" },
    { "path": "../../plugins/stack" }
  ]
}
